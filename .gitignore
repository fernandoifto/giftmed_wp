# Ambiente local
.env
.env.local
.env.*.local

# Backups e dumps (nunca versionar)
backup/
deploy/*
!deploy/.gitkeep
*.sql
*.sql.gz
*.tar.gz
*.zip
wp-config.php

# WordPress — uploads e cache
wp-content/uploads/*
!wp-content/uploads/.gitkeep
wp-content/cache/
wp-content/upgrade/
wp-content/upgrade-temp-backup/
wp-content/ai1wm-backups/*.wpress
wp-content/debug.log

# Temas padrão e idiomas (baixados no ambiente, não versionar)
wp-content/themes/twenty*/
wp-content/languages/

# Logs e SO
*.log
.DS_Store
Thumbs.db
