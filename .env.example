# Banco de dados
MYSQL_ROOT_PASSWORD=root_secret_change_me
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress_secret_change_me

# WordPress
WORDPRESS_PORT=8080
WORDPRESS_DEBUG=0

# URLs do site (produção: https://seudominio.com.br)
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080

# Seed de notícias fictícias — use 1 apenas em desenvolvimento local
GIFTMED_SEED_NOTICIAS=0

# Salts do WordPress (gerar em https://api.wordpress.org/secret-key/1.1/salt/)
# Em produção, preencha todos com valores únicos no Coolify.
WORDPRESS_AUTH_KEY=
WORDPRESS_SECURE_AUTH_KEY=
WORDPRESS_LOGGED_IN_KEY=
WORDPRESS_NONCE_KEY=
WORDPRESS_AUTH_SALT=
WORDPRESS_SECURE_AUTH_SALT=
WORDPRESS_LOGGED_IN_SALT=
WORDPRESS_NONCE_SALT=

# FTP (opcional — subir com: docker compose --profile ftp up -d)
# No Coolify: abra as portas 21 e 30000-30009 no firewall do servidor.
FTP_USER=giftmed
FTP_PASSWORD=altere_senha_ftp_forte
FTP_PUBLIC_HOST=127.0.0.1
